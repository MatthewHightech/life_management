generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum WeekDay {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
}

model Household {
  id             String            @id @default(cuid())
  name           String
  users          User[]
  projects       TaskProject[]
  tasks          Task[]
  recipes        Recipe[]
  folders        Folder[]
  receipts       Receipt[]
  mealPlanSlots  MealPlanSlot[]
  groceryItems   GroceryListItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  householdId   String?
  household     Household? @relation(fields: [householdId], references: [id])
  accounts      Account[]
  sessions      Session[]
  taskAssignments TaskAssignment[]
  createdTasks  Task[]     @relation("CreatedTasks")
  taskComments  TaskComment[]
  taskCommentReads TaskCommentRead[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model TaskProject {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name        String
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([householdId])
}

model Task {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  projectId   String?
  project     TaskProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentId    String?
  parent      Task?         @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]        @relation("Subtasks")

  title       String
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  isShared    Boolean       @default(true)

  assignments TaskAssignment[]
  createdById String
  createdBy   User          @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  dueDate     DateTime?
  completedAt DateTime?
  remindAt    DateTime?

  isRecurringTemplate Boolean              @default(false)
  recurrenceFrequency RecurrenceFrequency?
  recurrenceInterval  Int?
  recurrenceWeekdays  Int[]

  blockedBy TaskDependency[] @relation("BlockedTask")
  blocking  TaskDependency[] @relation("BlockingTask")
  comments  TaskComment[]
  commentReads TaskCommentRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId, dueDate])
  @@index([householdId, status])
  @@index([parentId])
}

model TaskAssignment {
  taskId     String
  userId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([taskId, userId])
  @@index([userId])
}

model TaskDependency {
  id              String @id @default(cuid())
  taskId          String
  task            Task   @relation("BlockedTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId String
  dependsOnTask   Task   @relation("BlockingTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

model TaskCommentRead {
  userId   String
  taskId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  readAt   DateTime @default(now())

  @@id([userId, taskId])
  @@index([taskId])
}

enum FolderNamespace {
  MEALS
  RECEIPTS
}

enum FolderColor {
  BLUSH
  SKY
  LAVENDER
  LEMON
  PEACH
  SAGE
}

model Folder {
  id          String          @id @default(cuid())
  householdId String
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  namespace   FolderNamespace
  parentId    String?
  parent      Folder?         @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]        @relation("FolderTree")
  name        String
  color       FolderColor
  recipes     Recipe[]
  receipts    Receipt[]
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([householdId, namespace, parentId])
}

model Receipt {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  fileName    String
  mimeType    String
  byteSize    Int
  storageKey  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([householdId, storageKey])
  @@index([householdId, folderId])
}

model Recipe {
  id           String             @id @default(cuid())
  householdId  String
  household    Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       Folder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name         String
  instructions String?
  servings     Int?
  ingredients  RecipeIngredient[]
  slots        MealPlanSlot[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([householdId])
  @@index([folderId])
}

model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  unit      String?
  sortOrder Int     @default(0)

  @@index([recipeId])
}

model MealPlanSlot {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  weekStart   DateTime  @db.Date
  day         WeekDay
  slot        MealSlot
  recipeId    String?
  recipe      Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([householdId, weekStart, day, slot])
  @@index([householdId, weekStart])
}

model GroceryListItem {
  id            String    @id @default(cuid())
  householdId   String
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  weekStart     DateTime  @db.Date
  name          String
  quantityLabel String    @default("")
  isBought      Boolean   @default(false)
  isManual      Boolean   @default(false)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([householdId, weekStart])
}
