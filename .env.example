# Database (local Docker Compose defaults)
DATABASE_URL="postgresql://life:life@localhost:5432/life_management"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# API server (local)
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
PORT=4000

# Web app (browser-facing API URL)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Local redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated allowlist of Google account emails
ALLOWED_EMAILS="you@example.com,partner@example.com"

# Plaid (bank sync) — https://dashboard.plaid.com/
# Start with sandbox keys; flip PLAID_ENV to production when ready for real TD/Simplii.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
# 32-byte key, base64: openssl rand -base64 32
PLAID_TOKEN_ENCRYPTION_KEY=""
# Optional: required for some OAuth institutions. Register in Plaid Dashboard → API → Allowed redirect URIs
# PLAID_REDIRECT_URI="http://localhost:3000/finance/budget"

# --- Production ---
# Copy .env.production.example → .env.production on the Oracle VM.
# Production uses docker-compose.prod.yml (Postgres + API + Web + Caddy on one VM).
