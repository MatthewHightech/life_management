# Database (local Docker Compose defaults)
DATABASE_URL="postgresql://life:life@localhost:5432/life_management"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# API server (local)
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
PORT=4000

# Web app (browser-facing API URL)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Local redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated allowlist of Google account emails
ALLOWED_EMAILS="you@example.com,partner@example.com"

# --- Production ---
# Copy .env.production.example → .env.production on the Oracle VM.
# Production uses docker-compose.prod.yml (Postgres + API + Web + Caddy on one VM).
