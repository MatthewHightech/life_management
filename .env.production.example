# Copy to .env.production on the Oracle VM (never commit the real file).
# cp .env.production.example .env.production

# --- Domains (DNS A records must point at the VM public IP) ---
WEB_DOMAIN=life.example.com
API_DOMAIN=api.life.example.com

# Public URLs (must match domains, use https after Caddy is running)
WEB_URL=https://life.example.com
API_URL=https://api.life.example.com

# --- Database (Postgres runs in Docker on the same VM) ---
POSTGRES_USER=life
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32
POSTGRES_DB=life_management

# --- Auth ---
# Generate: openssl rand -base64 32
AUTH_SECRET=

# --- Google OAuth ---
# Redirect URI: https://api.life.example.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist
ALLOWED_EMAILS=you@example.com,partner@example.com
