# Copy to .env.production on the Oracle VM (never commit the real file).
# cp .env.production.example .env.production

# --- Domains (DNS A records must point at the Oracle VM public IP) ---
# Production on mattsmith.sh subdomains (apex portfolio stays separate):
WEB_DOMAIN=life.mattsmith.sh
API_DOMAIN=api.life.mattsmith.sh

# Public URLs (must match domains, use https after Caddy is running)
WEB_URL=https://life.mattsmith.sh
API_URL=https://api.life.mattsmith.sh

# --- Database (Postgres runs in Docker on the same VM) ---
POSTGRES_USER=life
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32
POSTGRES_DB=life_management

# --- Auth ---
# Generate: openssl rand -base64 32
AUTH_SECRET=

# --- Google OAuth ---
# Redirect URI: https://api.life.mattsmith.sh/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist
ALLOWED_EMAILS=you@example.com,partner@example.com

# Plaid (bank sync)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
# openssl rand -base64 32
PLAID_TOKEN_ENCRYPTION_KEY=
# Optional OAuth redirect — register in Plaid Dashboard
# PLAID_REDIRECT_URI=https://life.mattsmith.sh/finance/budget
