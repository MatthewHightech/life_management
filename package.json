{
  "name": "life-management",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:api": "npm run dev -w @life/api",
    "dev:web": "npm run dev -w @life/web",
    "docker:prod": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "deploy": "./scripts/deploy.sh",
    "backup:db": "./scripts/backup-db.sh",
    "build": "npm run build -w @life/db && npm run build -w @life/web",
    "start": "docker compose up",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @life/db",
    "db:migrate": "npm run db:migrate -w @life/db",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @life/db",
    "db:seed": "npm run db:seed -w @life/db",
    "db:studio": "npm run db:studio -w @life/db",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
